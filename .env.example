# Copy to .env and fill in locally. Never commit real secrets.
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_PAIRING_SECRET=replace-with-one-time-random-secret
OPENAI_API_KEY=sk-replace-with-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-5.5
DATABASE_URL=sqlite+aiosqlite:///./data/assistant.db
REDIS_URL=
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_MB=25
MAX_CONCURRENT_TASKS=2
ENCRYPTION_KEY=replace-with-32-byte-base64-key
WORKSPACE_ROOT=./workspaces
